{
  "name": "oh-my-second-brain",
  "version": "0.1.7",
  "description": "Oh My Second Brain: a host-agnostic, user-owned convention layer for Obsidian and plain-markdown knowledge vaults.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "oh-my-second-brain": "dist/cli/oms.js",
    "oms": "dist/cli/oms.js",
    "oms-guard": "adapters/claude-code/hooks/oms-guard.mjs",
    "oms-post-guard": "adapters/claude-code/hooks/oms-post-guard.mjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "core",
    "adapters",
    "docs/install.md",
    "docs/release.md",
    "scripts/install.sh",
    "scripts/uninstall.sh"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "audit": "npm audit --omit=dev",
    "release:pack": "node scripts/release-pack.mjs",
    "release:setup-smoke": "node scripts/release-artifact-smoke.mjs --setup-only",
    "release:mcp-smoke": "node scripts/release-artifact-smoke.mjs --mcp-only",
    "release:artifact-smoke": "node scripts/release-artifact-smoke.mjs",
    "release:plugin": "node scripts/release-plugin.mjs",
    "release:check": "npm run lint && npm run build && npm test && npm run audit && npm run release:pack && npm run release:artifact-smoke && npm run release:plugin"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "node-llama-cpp": "^3.18.1",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoBeromsu/oh-my-second-brain.git"
  },
  "homepage": "https://github.com/GoBeromsu/oh-my-second-brain#readme",
  "bugs": {
    "url": "https://github.com/GoBeromsu/oh-my-second-brain/issues"
  },
  "keywords": [
    "obsidian",
    "knowledge-base",
    "mcp",
    "frontmatter",
    "markdown",
    "claude-code"
  ],
  "publishConfig": {
    "access": "public"
  }
}
